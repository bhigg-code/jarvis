# Jarvis Environment Variables
# Copy this to .env and fill in your values.
# Never commit .env to version control.

# ── ElevenLabs TTS ────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# ── Hermes API (OpenAI-compatible) ───────────────────────────────────────────
HERMES_API_BASE=http://127.0.0.1:8642/v1
HERMES_API_KEY=jarvis-api-key-local
HERMES_API_MODEL=hermes-agent

# ── Paths ─────────────────────────────────────────────────────────────────────
USER_HOME=/home/youruser
HERMES_HOME=/home/youruser/.hermes
HERMES_VENV=/home/youruser/.hermes/hermes-agent/venv
STATIC_DIR=/home/youruser/jarvis/static

# ── Speech ────────────────────────────────────────────────────────────────────
# Max chars before the reply gets summarised for TTS (default 300)
SPEECH_MAX_CHARS=300
